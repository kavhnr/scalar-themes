{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkBg": "#2f2e2c",
    "darkSurface": "#35342f",
    "darkHighlight": "#4b4943",
    "darkFg": "#d8d3ca",
    "darkSecondary": "#b8b2a8",
    "darkMuted": "#9b958b",
    "darkGreen": "#00b648",
    "darkRed": "#e53b39",
    "darkYellow": "#ffc90d",
    "darkBlue": "#4eb3ec",
    "darkOrange": "#ff8d4d",
    "darkPurple": "#b191f9",
    "darkDiffAddedBg": "#2e4633",
    "darkDiffRemovedBg": "#4e3530",
    "darkDiffAddedLineNumberBg": "#304132",
    "darkDiffRemovedLineNumberBg": "#473530",
    "lightBg": "#e6e6e6",
    "lightSurface": "#efefef",
    "lightHighlight": "#cecece",
    "lightFg": "#1f1f1f",
    "lightSecondary": "#5b5b5b",
    "lightMuted": "#686868",
    "lightGreen": "#078657",
    "lightRed": "#ef0006",
    "lightYellow": "#987100",
    "lightBlue": "#007ac2",
    "lightOrange": "#cc4700",
    "lightPurple": "#5203d1",
    "lightDiffAddedBg": "#cee0da",
    "lightDiffRemovedBg": "#efcdce",
    "lightDiffAddedLineNumberBg": "#d7e4df",
    "lightDiffRemovedLineNumberBg": "#efd7d7"
  },
  "theme": {
    "primary": { "dark": "darkBlue", "light": "lightBlue" },
    "secondary": { "dark": "darkPurple", "light": "lightPurple" },
    "accent": { "dark": "darkGreen", "light": "lightGreen" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkYellow", "light": "lightYellow" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkFg", "light": "lightFg" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkSurface", "light": "lightSurface" },
    "backgroundElement": { "dark": "darkHighlight", "light": "lightHighlight" },
    "border": { "dark": "darkHighlight", "light": "lightHighlight" },
    "borderActive": { "dark": "darkBlue", "light": "lightBlue" },
    "borderSubtle": { "dark": "darkSurface", "light": "lightSurface" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkBlue", "light": "lightBlue" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "darkDiffAddedBg", "light": "lightDiffAddedBg" },
    "diffRemovedBg": {
      "dark": "darkDiffRemovedBg",
      "light": "lightDiffRemovedBg"
    },
    "diffContextBg": { "dark": "darkSurface", "light": "lightSurface" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": {
      "dark": "darkDiffAddedLineNumberBg",
      "light": "lightDiffAddedLineNumberBg"
    },
    "diffRemovedLineNumberBg": {
      "dark": "darkDiffRemovedLineNumberBg",
      "light": "lightDiffRemovedLineNumberBg"
    },
    "markdownText": { "dark": "darkFg", "light": "lightFg" },
    "markdownHeading": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownLink": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownLinkText": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownCode": { "dark": "darkOrange", "light": "lightOrange" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkFg", "light": "lightFg" },
    "markdownStrong": { "dark": "darkFg", "light": "lightFg" },
    "markdownHorizontalRule": {
      "dark": "darkHighlight",
      "light": "lightHighlight"
    },
    "markdownListItem": { "dark": "darkSecondary", "light": "lightSecondary" },
    "markdownListEnumeration": {
      "dark": "darkSecondary",
      "light": "lightSecondary"
    },
    "markdownImage": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownImageText": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownCodeBlock": { "dark": "darkSurface", "light": "lightSurface" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkPurple", "light": "lightPurple" },
    "syntaxFunction": { "dark": "darkOrange", "light": "lightOrange" },
    "syntaxVariable": { "dark": "darkFg", "light": "lightFg" },
    "syntaxString": { "dark": "darkBlue", "light": "lightBlue" },
    "syntaxNumber": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxType": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxOperator": { "dark": "darkSecondary", "light": "lightSecondary" },
    "syntaxPunctuation": { "dark": "darkMuted", "light": "lightMuted" }
  }
}
